{
  "name": "nicosoft-ai-studio",
  "version": "1.0.1",
  "description": "An open-source desktop AI workshop — a team of specialized AI experts that collaborate.",
  "author": "NicoSoft",
  "license": "Apache-2.0",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "e2e:smoke": "node e2e/smoke.mjs",
    "e2e:engineer": "node e2e/engineer-agent.mjs",
    "e2e:title-memory": "node e2e/title-memory.mjs",
    "test:collab": "node --experimental-transform-types e2e/collab-scheduler.mts",
    "test:lens": "node --experimental-transform-types --import ./e2e/_register.mjs e2e/lens-maxturns.mts && node --experimental-transform-types --import ./e2e/_register.mjs e2e/lens-tiers.mts && node --experimental-transform-types --import ./e2e/_register.mjs e2e/lens-script-executor.mts && node --experimental-transform-types --import ./e2e/_register.mjs e2e/lens-code-review.mts && node --experimental-transform-types --import ./e2e/_register.mjs e2e/lens-agent-lens.mts",
    "test:preview": "node --experimental-transform-types --import ./e2e/_register.mjs e2e/preview-tools.mts",
    "test:preview-ssrf": "node --experimental-transform-types --import ./e2e/_register.mjs e2e/preview-url-guard.mts",
    "test:self-wakeup": "node --experimental-transform-types --import ./e2e/_register.mjs --import ./e2e/_stub-electron.mjs e2e/self-wakeup.mts",
    "rebuild:native": "electron-rebuild --only node-pty --force",
    "postinstall": "node scripts/ensure-electron.mjs && node scripts/rebuild-native.mjs"
  },
  "dependencies": {
    "@fontsource/inter": "^5.1.1",
    "@fontsource/jetbrains-mono": "^5.1.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "acorn": "^8.17.0",
    "acorn-walk": "^8.3.5",
    "electron-updater": "^6.8.9",
    "js-yaml": "^4.2.0",
    "markdown-it": "^14.2.0",
    "node-pty": "^1.1.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.1.0",
    "three": "^0.184.0",
    "turndown": "^7.2.4",
    "typescript-language-server": "^5.3.0",
    "ulid": "^3.0.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/three": "^0.184.1",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.15.0",
    "electron-vite": "^5.0.0",
    "playwright": "^1.60.0",
    "typescript": "^6.0.3",
    "vite": "^7.0.0"
  }
}
